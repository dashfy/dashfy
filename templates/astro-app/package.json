{
  "name": "astro-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:server": "dotenv -e .env -- tsx watch dashfy.server.ts",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev\"",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,astro,css,md,json,yml}\"",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.0",
    "@dashfy/ext-github": "^0.1.0",
    "@dashfy/ext-market-live": "^0.1.0",
    "@dashfy/ext-nba": "^0.1.0",
    "@dashfy/ext-system": "^0.1.0",
    "@dashfy/server": "^0.1.0",
    "@dashfy/ui": "^0.1.0",
    "astro": "^6.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.8.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "concurrently": "^9.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
