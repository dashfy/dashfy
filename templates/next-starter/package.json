{
  "name": "next-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:server": "dotenv -e .env -- tsx watch dashfy.server.ts",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json,yml}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@getdashfy/server": "^0.1.0",
    "@getdashfy/ui": "^0.1.0",
    "next": "^16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "concurrently": "^9.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.6",
    "prettier": "^3.4.2",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2"
  }
}
