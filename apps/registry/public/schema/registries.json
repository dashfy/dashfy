{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dashfy.dev/schema/registries.json",
  "title": "Dashfy Registries Discovery Index",
  "description": "The catalog of known public registries served at /registries.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["registries"],
  "properties": {
    "$schema": { "type": "string" },
    "registries": {
      "type": "object",
      "description": "Map of @namespace to its registry endpoint.",
      "propertyNames": { "pattern": "^@" },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL template containing the {name} placeholder.",
            "pattern": "\\{name\\}"
          },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "homepage": { "type": "string" }
        }
      }
    }
  }
}
