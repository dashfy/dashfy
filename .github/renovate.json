{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "labels": ["dependencies", "renovate"],
  "assignees": ["brenopolanski"],
  "ignorePaths": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/.turbo/**"],
  "rebaseWhen": "never",
  "packageRules": [
    {
      "matchPackageNames": [
        "@dashfy/cli",
        "@dashfy/server",
        "@dashfy/themes",
        "@getdashfy/types",
        "@dashfy/ui",
        "@dashfy/utils"
      ],
      "groupName": "dashfy monorepo packages",
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "devDependencies (non-major)"
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update", "renovate"]
    },
    {
      "matchPackageNames": ["pnpm"],
      "rangeStrategy": "bump"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security", "renovate"],
    "assignees": ["brenopolanski"]
  }
}
