{
  "name": "dashfy",
  "version": "0.1.0",
  "description": "Dashfy CLI - scaffold dashboards and add extensions",
  "keywords": [
    "dashfy",
    "cli",
    "dashboard",
    "scaffold",
    "extensions"
  ],
  "homepage": "https://github.com/dashfy/dashfy#readme",
  "bugs": {
    "url": "https://github.com/dashfy/dashfy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dashfy/dashfy.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": {
    "name": "Breno Polanski",
    "email": "breno.polanski@gmail.com",
    "url": "https://github.com/brenopolanski"
  },
  "type": "module",
  "bin": {
    "dashfy": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo dist node_modules",
    "dev": "tsup --watch",
    "registry:build": "tsx scripts/build-registry.ts",
    "registry:validate": "tsx scripts/validate-registry.ts",
    "mcp:inspect": "pnpm dlx @modelcontextprotocol/inspector tsx src/index.ts mcp",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "fuzzysort": "^3.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0",
    "undici": "^6.22.0",
    "yaml": "^2.8.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@dashfy/tsconfig": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.8.6",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
